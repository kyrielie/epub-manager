{
  "name": "epub-manager",
  "version": "1.0.0",
  "description": "Fast Calibre library browser with custom tagging and ELO ranking",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3"
  },
  "build": {
    "appId": "com.epub.manager",
    "productName": "EPUB Manager",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "files": ["src/**/*", "assets/**/*", "node_modules/**/*"]
  }
}